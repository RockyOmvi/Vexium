use ai
use network
use system
use concurrent

display "=== 1. AI Native Module ==="
let tensor be create_tensor([1000, 1000], "gpu", "random")
display "Tensor initialized on compute device."

let model be NeuralNetwork([dense_layer(784, 256, "relu"), dense_layer(256, 10, "softmax")])
train_model(model, [], {"epochs": 10})

display "=== 2. Native Networking Module ==="
let response be get("https://api.vexium.org/health")
display response["body"]

display "=== 3. Unsafe Memory & System Operations ==="
let ptr be allocate(1024)
write_memory(ptr, 0, 42)
let val be read_memory(ptr, 0)
display val
free_memory(ptr)

display "=== V2 EVOLUTION ALL TESTS PASSED ==="
