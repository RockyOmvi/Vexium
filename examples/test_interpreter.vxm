# ╔══════════════════════════════════════════╗
# ║  Vex Interpreter Test Suite             ║
# ╚══════════════════════════════════════════╝

# ── Variables & Arithmetic ──
display "=== Variables & Arithmetic ==="
let x be 10
let y be 3
display x + y
display x - y
display x * y
display x / y
display x % y
display 2 ** 10
const PI be 3.14159
display PI

# ── String Operations ──
display "=== Strings ==="
let name be "Vex"
display "Hello, {name}!"
display "ha" * 3
let greeting be "Hello" + " " + "World"
display greeting
display len(greeting)

# ── Boolean & Nothing ──
display "=== Booleans ==="
display true
display false
display not false
display nothing

# ── If / Elif / Else ──
display "=== Control Flow ==="
let score be 85
if score is greater than 90:
    display "Grade: A"
elif score is greater than 80:
    display "Grade: B"
elif score is greater than 70:
    display "Grade: C"
else:
    display "Grade: F"

# ── While Loop ──
display "=== While Loop ==="
let count be 0
while count is less than 5:
    display count
    count be count + 1

# ── For Range ──
display "=== For Range ==="
for i in 1 to 5:
    display i

# ── For Each ──
display "=== For Each ==="
let fruits be ["apple", "banana", "cherry"]
for each fruit in fruits:
    display fruit

# ── Repeat ──
display "=== Repeat ==="
repeat 3 times:
    display "Vex!"

# ── Functions ──
display "=== Functions ==="
fn add(a, b):
    give back a + b

fn factorial(n):
    if n is at most 1:
        give back 1
    give back n * factorial(n - 1)

display add(10, 20)
display factorial(5)
display factorial(10)

# ── Match ──
display "=== Match ==="
let day be 3
match day:
    1 => display "Monday"
    2 => display "Tuesday"
    3 => display "Wednesday"

# ── English Operators ──
display "=== English Operators ==="
let age be 25
if age is at least 18:
    display "Adult"
if age is at most 30:
    display "Young"
if age is not 0:
    display "Alive"

# ── Arrays & Maps ──
display "=== Collections ==="
let colors be ["red", "green", "blue"]
display colors
display colors[0]
display colors[-1]
display len(colors)

let person be {"name": "Alice", "age": 30}
display person

# ── Structs ──
display "=== Structs ==="
struct Dog:
    has name: str
    has age: int

    can bark(self):
        display "{self.name} says: Woof!"

    can info(self):
        display "{self.name} is {self.age} years old"

let rex be Dog("Rex", 3)
display rex.name
display rex.age
rex.bark()
rex.info()

# ── Type Casting ──
display "=== Type Casting ==="
display int("42")
display float(10)
display str(3.14)
display type(42)
display type("hello")

# ── Compound Assignment ──
display "=== Compound Assignment ==="
let val be 10
val += 5
display val
val -= 3
display val
val *= 2
display val

# ── Attempt / Otherwise ──
display "=== Error Handling ==="
attempt:
    display "Trying something..."
otherwise err:
    display "Something went wrong"

display "=== ALL TESTS PASSED ==="
