{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": ".*:\\s*$",
    "decreaseIndentPattern": "^\\s*#|^\\s*(elif|else|end)\\b.*:$"
  },
  "folding": {
    "markers": {
      "start": "^\\s*#\\s*\\{\\{\\{",
      "end": "^\\s*#\\s*\\}\\}\\}"
    }
  }
}
