{
  "name": "vexium-language",
  "displayName": "Vexium Language",
  "description": "Language support for Vexium programming language",
  "version": "2.3.1",
  "publisher": "vexium",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vexium",
        "aliases": [
          "Vexium",
          "vexium"
        ],
        "extensions": [
          ".vxm",
          ".vxmc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vexium",
        "scopeName": "source.vexium",
        "path": "./syntaxes/vexium.json"
      }
    ],
    "snippets": [
      {
        "language": "vexium",
        "path": "./snippets/vexium.json"
      }
    ],
    "iconThemes": [
      {
        "id": "vexium-icons",
        "label": "Vexium File Icons",
        "path": "./icons/vexium-icon-theme.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vexium/vexium-vscode"
  },
  "keywords": [
    "vexium",
    "language"
  ],
  "files": [
    "icon.png",
    "language-configuration.json",
    "syntaxes/**",
    "snippets/**",
    "icons/**",
    "README.md",
    "LICENSE.txt",
    "package.json"
  ]
}
