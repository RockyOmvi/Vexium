# Feature Verification Test
# This test verifies that all 5 core language features are recognized by the parser

# 1. DEFER - Scheduling deferred execution
fn test_defer():
    defer display "deferred cleanup"
    give back 42

# 2. AWAIT - Waiting for async operations  
task async_func():
    give back "result"

fn test_await():
    value be await async_func()
    give back value

# 3. TRAITS - Defining method contracts
trait Drawable:
    can draw()
    can get_size()

# 4. IMPL - Implementing trait methods
struct Button:
    has width: int
    has height: int
    
    can create(w: int, h: int):
        self.width be w
        self.height be h

impl Drawable for Button:
    can draw():
        display "Drawing button"
    
    can get_size():
        give back self.width * self.height

# 5. OPERATOR OVERLOADING - Custom operator behavior
struct Point:
    has x: int
    has y: int
    
    can create(px: int, py: int):
        self.x be px
        self.y be py
    
    can operator +(other: Point):
        result be Point(self.x + other.x, self.y + other.y)
        give back result

# 6. TAIL CALL OPTIMIZATION (in recursive calls)
fn countdown(n):
    if n <= 0:
        display "Done"
        give back nothing
    display n
    # Tail call - optimized by VM
    give back countdown(n - 1)

fn verify():
    display "=== Core Language Features ==="
    display "✓ Defer statements"
    display "✓ Await expressions"
    display "✓ Traits"
    display "✓ Impl blocks"
    display "✓ Operator overloading"
    display "✓ Tail call optimization"

verify()
