use math
display "=== STDLIB COMPAT TEST ==="
display sqrt(16)
display abs(-42)
display pow(2, 5)
display min(7, 3)
display max(7, 3)

let values be [1, 2, 3, 4]
let total be 0
let i be 0
while i < len(values):
	total be total + values[i]
	i be i + 1

display total
display "ALL STDLIB TESTS PASSED"
