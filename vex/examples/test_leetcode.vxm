#  TEST 9: FizzBuzz
# ═══════════════════════════════════════════════════════════════
display "=== 9. FizzBuzz ==="

fn fizzbuzz(n):
    if n % 15 == 0:
        give back "FizzBuzz"
    elif n % 3 == 0:
        give back "Fizz"
    elif n % 5 == 0:
        give back "Buzz"
    give back n

let fb_result be []
for i in 1 to 16:
    push(fb_result, fizzbuzz(i))
display fb_result

# ═══════════════════════════════════════════════════════════════
#  TEST 10: Single Number (LeetCode #136)
# ═══════════════════════════════════════════════════════════════
display "=== 10. Single Number ==="

fn single_number(nums):
    let sorted_list be sort(nums)
    let i be 0
    while i < len(sorted_list) - 1:
        if sorted_list[i] != sorted_list[i + 1]:
            give back sorted_list[i]
        i += 2
    give back sorted_list[len(sorted_list) - 1]

display single_number([2, 2, 1])
display single_number([4, 1, 2, 1, 2])

# ═══════════════════════════════════════════════════════════════
#  TEST 11: Count Primes (LeetCode #204)
# ═══════════════════════════════════════════════════════════════
display "=== 11. Count Primes ==="

fn count_primes(n):
    let c be 0
    for i in 2 to n:
        if is_prime(i):
            c += 1
    give back c

display count_primes(20)
display count_primes(100)

# ═══════════════════════════════════════════════════════════════
#  TEST 12: Power Function (LeetCode #50)
# ═══════════════════════════════════════════════════════════════
display "=== 12. Power ==="

fn my_pow(base, exp):
    if exp == 0:
        give back 1
    if exp < 0:
        give back 1.0 / my_pow(base, 0 - exp)
    if exp % 2 == 0:
        let half be my_pow(base, exp / 2)
        give back half * half
    give back base * my_pow(base, exp - 1)

display my_pow(2, 10)
display my_pow(3, 5)

# ═══════════════════════════════════════════════════════════════
#  TEST 13: Kadane's Algorithm (LeetCode #53)
# ═══════════════════════════════════════════════════════════════
display "=== 13. Max Subarray ==="

fn max_subarray(nums):
    let max_sum be nums[0]
    let current be nums[0]
    let i be 1
    while i < len(nums):
        let candidate be current + nums[i]
        if candidate > nums[i]:
            current be candidate
        elif nums[i] > current:
            current be nums[i]
        if current > max_sum:
            max_sum be current
        i += 1
    give back max_sum

display max_subarray([-2, 1, -3, 4, -1, 2, 1, -5, 4])

