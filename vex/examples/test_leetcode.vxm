# ═══════════════════════════════════════════════════════════════
#  TEST 5: LeetCode #1 — Two Sum
# ═══════════════════════════════════════════════════════════════
display "=== 5. Two Sum ==="

fn two_sum(nums, target):
    let i be 0
    while i < len(nums):
        let j be i + 1
        while j < len(nums):
            if nums[i] + nums[j] == target:
                give back [i, j]
            j += 1
        i += 1
    give back []

display two_sum([2, 7, 11, 15], 9)
display two_sum([3, 2, 4], 6)

