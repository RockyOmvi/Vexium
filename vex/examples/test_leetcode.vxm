display is_palindrome("hello")
display is_palindrome("madam")

# ═══════════════════════════════════════════════════════════════
#  TEST 7: LeetCode #20 — Valid Parentheses (Stack)
# ═══════════════════════════════════════════════════════════════
display "=== 7. Valid Parens ==="

fn check_parens(s):
    let stack be []
    let i be 0
    while i < len(s):
        let c be char_at(s, i)
        if c == "(" or c == "[" or c == "{":
            push(stack, c)
        if c == ")" or c == "]" or c == "}":
            if len(stack) == 0:
                give back false
            let top be pop(stack)
            if c == ")" and top != "(":
                give back false
            if c == "]" and top != "[":
                give back false
            if c == "}" and top != "{":
                give back false
        i += 1
    give back len(stack) == 0

display check_parens("([]{})")
display check_parens("([)]")
display check_parens("{[]}")

