display "=== AI V2 COMPAT TEST ==="

fn linear_score(weights, features, bias):
	let total be bias
	total be total + (weights * features)
	give back total

fn classify(score):
	if score > 5:
		give back "high"
	elif score > 2:
		give back "medium"
	else:
		give back "low"

let weight be 2
let sample_a be 3
let sample_b be 1

let score_a be linear_score(weight, sample_a, 1)
let score_b be linear_score(weight, sample_b, 1)

display score_a
display classify(score_a)
display score_b
display classify(score_b)
display "AI V2 COMPAT PASS"
