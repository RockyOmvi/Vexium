# Comprehensive Test Suite for Vexium v2.0
# Tests all major features and components

display "════════════════════════════════════════════════════"
display "VEXIUM V2.0 COMPREHENSIVE TEST SUITE"
display "════════════════════════════════════════════════════"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 1: BASIC DATA TYPES
# ═══════════════════════════════════════════════════════════
display "TEST 1: BASIC DATA TYPES"
let int_val be 42
let float_val be 3.14159
let string_val be "Hello, Vexium"
let bool_val be true
let nothing_val be nothing

display "  Integer: {int_val}"
display "  Float: {float_val}"
display "  String: {string_val}"
display "  Boolean: {bool_val}"
display "  Nothing: {nothing_val}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 2: ARRAYS
# ═══════════════════════════════════════════════════════════
display "TEST 2: ARRAYS"
let array be [1, 2, 3, 4, 5]
display "  Array: {array}"
display "  Length: {len(array)}"
display "  First: {array[0]}, Last: {array[4]}"
array.push(6)
display "  After push(6): {array}"
let popped be array.pop()
display "  Popped: {popped}, Array: {array}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 3: MAPS/DICTIONARIES
# ═══════════════════════════════════════════════════════════
display "TEST 3: MAPS/DICTIONARIES"
let map be {"name": "Alice", "age": 30, "city": "NYC"}
display "  Map: {map}"
display "  Name: {map[\"name\"]}, Age: {map[\"age\"]}"
display "  Map size: {len(map)}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 4: CONTROL FLOW - IF/ELIF/ELSE
# ═══════════════════════════════════════════════════════════
display "TEST 4: CONTROL FLOW - IF/ELIF/ELSE"
let score be 85
if score greater than or equal 90:
    display "  Grade: A"
elif score greater than or equal 80:
    display "  Grade: B (85)-- {score}"
elif score greater than or equal 70:
    display "  Grade: C"
else:
    display "  Grade: F"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 5: LOOPS - WHILE
# ═══════════════════════════════════════════════════════════
display "TEST 5: LOOPS - WHILE"
let count be 0
let sum be 0
while count less than 5:
    sum be sum + count
    count be count + 1
display "  Sum of 0-4: {sum}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 6: LOOPS - FOR/IN
# ═══════════════════════════════════════════════════════════
display "TEST 6: LOOPS - FOR/IN"
let total be 0
for item in [10, 20, 30, 40]:
    total be total + item
display "  Sum of array: {total}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 7: LOOPS - RANGE
# ═══════════════════════════════════════════════════════════
display "TEST 7: LOOPS - RANGE"
let range_sum be 0
for i in 1 to 5:
    range_sum be range_sum + i
display "  Sum 1 to 4: {range_sum}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 8: LOOPS - REPEAT
# ═══════════════════════════════════════════════════════════
display "TEST 8: LOOPS - REPEAT"
let repeat_count be 0
repeat 3 times:
    repeat_count be repeat_count + 1
display "  Repeat counter: {repeat_count}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 9: BREAK AND SKIP
# ═══════════════════════════════════════════════════════════
display "TEST 9: BREAK AND SKIP"
let break_sum be 0
for i in 0 to 10:
    if i is 5:
        break
    break_sum be break_sum + i
display "  Sum before break at 5: {break_sum}"

let skip_sum be 0
for i in 0 to 5:
    if i % 2 is 0:
        skip
    skip_sum be skip_sum + i
display "  Sum of odd numbers: {skip_sum}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 10: FUNCTIONS
# ═══════════════════════════════════════════════════════════
display "TEST 10: FUNCTIONS"
fn add(a, b):
    give back a + b

fn factorial(n):
    if n less than or equal 1:
        give back 1
    give back n * factorial(n - 1)

display "  add(5, 3) = {add(5, 3)}"
display "  factorial(5) = {factorial(5)}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 11: CLOSURES
# ═══════════════════════════════════════════════════════════
display "TEST 11: CLOSURES"
fn make_multiplier(factor):
    fn multiply(x):
        give back x * factor
    give back multiply

let times3 be make_multiplier(3)
let times5 be make_multiplier(5)
display "  times3(10) = {times3(10)}"
display "  times5(10) = {times5(10)}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 12: STRINGS
# ═══════════════════════════════════════════════════════════
display "TEST 12: STRING METHODS"
let text be "Hello, World"
display "  Original: {text}"
display "  Upper: {text.upper()}"
display "  Lower: {text.lower()}"
display "  Length: {text.length()}"
display "  Contains 'World': {text.contains(\"World\")}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 13: MATH MODULE
# ═══════════════════════════════════════════════════════════
display "TEST 13: MATH MODULE"
use math
display "  PI = {PI}"
display "  sqrt(16) = {sqrt(16)}"
display "  abs(-42) = {abs(-42)}"
display "  pow(2, 10) = {pow(2, 10)}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 14: ERROR HANDLING
# ═══════════════════════════════════════════════════════════
display "TEST 14: ERROR HANDLING"
attempt:
    fn divide(a, b):
        if b is 0:
            throw "Division by zero"
        give back a / b
    
    let result be divide(10, 2)
    display "  10 / 2 = {result}"
    
    attempt:
        divide(10, 0)
    otherwise err:
        display "  Caught error: {err}"
otherwise:
    display "  Error during division test"

display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 15: STRUCTS
# ═══════════════════════════════════════════════════════════
display "TEST 15: STRUCTS"
struct Person:
    has name
    has age
    
    can describe():
        give back "{self.name} is {self.age} years old"

let person be Person()
person.name be "Bob"
person.age be 25
display "  Created: {person.describe()}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 16: PATTERN MATCHING
# ═══════════════════════════════════════════════════════════
display "TEST 16: PATTERN MATCHING"
let day be 3
match day:
    when 1:
        display "  Monday"
    when 2:
        display "  Tuesday"
    when 3:
        display "  Wednesday"
    otherwise:
        display "  Other day"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 17: LIST COMPREHENSIONS
# ═══════════════════════════════════════════════════════════
display "TEST 17: LIST COMPREHENSIONS"
let numbers be [1, 2, 3, 4, 5]
let squared be [x * x for x in numbers]
display "  Numbers: {numbers}"
display "  Squared: {squared}"
let evens be [x for x in numbers where x % 2 is 0]
display "  Even numbers: {evens}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# TEST 18: FIRST-CLASS FUNCTIONS
# ═══════════════════════════════════════════════════════════
display "TEST 18: FIRST-CLASS FUNCTIONS"
let square be fn(x): give back x * x
let cube be fn(x): give back x * x * x

fn apply(f, value):
    give back f(value)

display "  apply(square, 5) = {apply(square, 5)}"
display "  apply(cube, 3) = {apply(cube, 3)}"
display "  ✓ PASS"
display ""

# ═══════════════════════════════════════════════════════════
# FINAL SUMMARY
# ═══════════════════════════════════════════════════════════
display "════════════════════════════════════════════════════"
display "ALL TESTS PASSED ✓"
display "════════════════════════════════════════════════════"
