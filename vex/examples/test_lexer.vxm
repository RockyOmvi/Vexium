# Test file exercising ALL Vex token types

# Variables
let count be 0
let name be "Alice"
const PI be 3.14159
const MAX be 1024

# Numbers
let hex_val be 0xFF
let bin_val be 0b1010
let big_num be 1_000_000
let sci be 1.5e10

# Functions
fn greet(person: str) -> str:
    give back "Hello, {person}!"

fn add(a: int, b: int) -> int:
    give back a + b

# Control flow
if count is 0:
    display "Count is zero"
elif count is greater than 10:
    display "Count is big"
elif count is less than 0:
    display "Negative!"
else:
    display "Something else"

# Loops
while count is less than 10:
    count be count + 1

for i in 1 to 20 by 2:
    display i

for each item in ["apple", "banana"]:
    display item

repeat 5 times:
    display "Hello!"

# Pattern matching
match count:
    0 => display "zero"
    1 => display "one"

# Operators
let x be 10 + 5
let y be x * 2
let z be y / 3
let w be z % 4
let p be 2 ** 8

# Comparisons
if x == 15:
    pass
if x != 20:
    pass
if x >= 10:
    pass
if x <= 20:
    pass

# English comparisons
if x is 15:
    display "fifteen"
if x is not 20:
    display "not twenty"
if x is at least 10:
    display "at least ten"
if x is at most 100:
    display "at most hundred"

# Logic
if x > 0 and y > 0:
    display "both positive"
if x > 100 or y > 100:
    display "one is big"
if not false:
    display "true!"

# Structs
struct Dog:
    has name: str
    has age: int

    can bark(self):
        display "Woof!"

# Collections
let fruits be ["apple", "banana"]
let ages be {"alice": 30, "bob": 25}

# Error handling
attempt:
    display "trying"
otherwise err:
    display "failed"

# Modules
use math
from math use sqrt

# Special
let maybe be nothing
if maybe is nothing:
    display "nothing there"

display "All tokens tested!"
