display "=== DECORATOR COMPAT TEST ==="

fn hello():
    give back "Hello from decorated!"

fn emphasize(text):
    give back text + "!"

let msg be hello()
display msg
display emphasize(msg)
display len(msg)

# Higher-order function pattern (decorator analog)
fn logged(fn_name, value):
    display fn_name
    give back value

fn add(a, b):
    give back a + b

fn mul(a, b):
    give back a * b

let r1 be logged("add", add(3, 4))
let r2 be logged("mul", mul(3, 4))
display r1
display r2

# Apply pattern — run a function on each element
fn apply(f, a, b):
    give back f(a, b)

display apply(add, 10, 5)
display apply(mul, 10, 5)

display "DECORATOR PASS"
