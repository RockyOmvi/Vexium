display "=== ERROR HANDLING COMPAT TEST ==="

fn safe_divide(a, b):
	if b == 0:
		give back "division-by-zero"
	give back a / b

display safe_divide(20, 2)
display safe_divide(20, 0)

let status be "ok"
if safe_divide(9, 3) == 3:
	status be "checked"

display status
display "Error handling tests complete!"
