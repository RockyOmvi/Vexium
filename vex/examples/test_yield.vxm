# Sequential value generation test (iterator-like patterns)
display "=== SEQUENTIAL VALUES TEST ==="

# Compute nth fibonacci iteratively (generator-equivalent)
fn fibonacci_at(n):
    if n == 0:
        give back 0
    if n == 1:
        give back 1
    let a be 0
    let b be 1
    let i be 2
    while i <= n:
        let tmp be a + b
        a be b
        b be tmp
        i be i + 1
    give back b

display fibonacci_at(0)
display fibonacci_at(1)
display fibonacci_at(5)
display fibonacci_at(10)

# Produce values iteratively with accumulation
let total be 0
let j be 0
while j < 5:
    total be total + fibonacci_at(j)
    j be j + 1
display total

display "SEQUENTIAL VALUES PASS"
