# Lambda / arrow function
let square be (x) => x * x
display square(5)
display square(12)

# Named function as value
fn cube(x):
    give back x * x * x

let cube_fn be cube
display cube_fn(3)

# Module imports work
from math use sqrt
from math use abs
display sqrt(144)
display abs(-99)

# String module
from string use upper
from string use lower
display upper("hello")
display lower("WORLD")

