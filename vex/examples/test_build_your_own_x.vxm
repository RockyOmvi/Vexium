display "=== BUILD YOUR OWN X COMPAT TEST ==="

fn transform(x):
    give back (x * 2) + 1

fn run_pipeline(values):
    let out be []
    let i be 0
    while i < len(values):
        push(out, transform(values[i]))
        i be i + 1
    give back out

let input be [1, 2, 3, 4]
let output be run_pipeline(input)

display output
display output[0]
display output[3]
display "BUILD YOUR OWN X COMPAT PASS"
