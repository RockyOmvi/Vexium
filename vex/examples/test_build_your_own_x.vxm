# ─────────────────────────────────────────────────────────────
# Test 1: Neural Network (nn.vxm)
# ─────────────────────────────────────────────────────────────
display ""
display "=== Test 1: Neural Network Library ==="

use nn

# Test activation functions
let sig_val be sigmoid(0)
display "sigmoid(0) = " + str(sig_val)

let relu_val be relu(-5)
display "relu(-5) = " + str(relu_val)

# Test dense layer
let layer be Dense.create(2, 3, "relu")
let input be [1, 2]
let output be layer.forward(input)
display "Dense layer output: " + str(output)

# Test neural network
let nn_model be NeuralNetwork.create(0.01)
nn_model.add_layer(Dense.create(2, 4, "relu"))
nn_model.add_layer(Dense.create(4, 1, "sigmoid"))

display "Neural Network test: PASSED"


