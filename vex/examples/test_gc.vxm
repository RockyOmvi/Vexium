fn make_large_list(n):
    let result be []
    for i in 0 to n + 1:
        push(result, i)
    give back result

fn test_gc():
    display "Testing GC..."
    
    for i in 0 to 100:
        let temp be make_large_list(100)
    
    display "Loop 1 complete"
    
    let survivors be []
    for i in 0 to 100:
        push(survivors, make_large_list(10))
    
    display "Created survivors"
    
    for i in 0 to 100:
        make_large_list(100)
    
    display "Loop 2 complete"
    
    let total be 0
    for each list in survivors:
        for each val in list:
            total = total + val
    
    display "Total: " + str(total)
    
    let closures be []
    for i in 0 to 50:
        let captured be i * 10
        let f be (x) => x + captured
        push(closures, f)
    
    let closure_sum be 0
    for each f in closures:
        closure_sum = closure_sum + f(1)
    
    display "Closure sum: " + str(closure_sum)
    display "GC test complete!"

test_gc()
