# GC stress test - exercises allocation-heavy patterns across scopes
display "=== GC STRESS TEST ==="

# Many intermediate allocations in a recursive function
fn sum_recursive(n):
    if n <= 0:
        give back 0
    give back n + sum_recursive(n - 1)

display sum_recursive(50)

# Many function calls that each create local values
fn make_pair(a, b):
    let lo be a
    let hi be b
    give back lo + hi

let acc be 0
let k be 0
while k < 20:
    acc be acc + make_pair(k, k + 1)
    k be k + 1
display acc

# Nested arrays - multiple allocations in one scope
let mat be [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
display mat[0][0]
display mat[1][1]
display mat[2][2]

# Verify correctness after prior allocations
fn fib(n):
    if n <= 1:
        give back n
    give back fib(n - 1) + fib(n - 2)

display fib(10)
display fib(15)

display "GC STRESS PASS"
