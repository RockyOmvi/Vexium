# Test: Await Expressions
# Await is used to wait for asynchronous operations to complete
# Makes async code look synchronous

task fetch_data(url):
    # Simulates an async operation that fetches data
    display "Fetching from: " + url
    give back "ok data"

fn async_example():
    display "=== Testing Await Expressions ==="
    display "Standard synchronous call:"
    let result be fetch_data("https://api.example.com/data")
    display "Result: " + result  
    display ""
    
    display "With await (for future async support):"
    # Awaiting a promise/task result
    let data be await fetch_data("https://api.example.com/users")
    display "Async data: " + data

fn async_multiple():
    display "=== Multiple Async Operations ==="
    display "Fetching multiple resources..."
    
    let user_data be await fetch_data("https://api.example.com/users")
    let product_data be await fetch_data("https://api.example.com/products")
    let order_data be await fetch_data("https://api.example.com/orders")
    
    display "Received user data: " + user_data
    display "Received product data: " + product_data
    display "Received order data: " + order_data

fn error_handling_async():
    display "=== Async Error Handling ==="
    attempt:
        let result be await fetch_data("https://api.example.com/invalid")
        display "Success: " + result
    otherwise err:
        display "Error fetching data: " + err

# Run tests
async_example()
display ""
async_multiple()
display ""
error_handling_async()
