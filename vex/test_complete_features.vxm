# Vexium Core Language Features Implementation Test

fn test_defer_parsing():
    display "=== DEFER PARSING TEST ==="
    defer display "Deferred code works"
    display "Main code"

fn test_await_parsing():
    display "=== AWAIT PARSING TEST ==="
    # await works with any expression
    value be await 42
    display "Await value: " + type(value)

trait Printable:
    can print_item()

struct Document:
    has title: str
    
    can create(t: str):
        self.title be t

impl Printable for Document:
    can print_item():
        display "Document: " + self.title

struct Number:
    has value: int
    
    can create(v: int):
        self.value be v
    
    can operator +(other: Number):
        result be Number(self.value + other.value)
        give back result

fn test_features():
    display ""
    display "=== ALL CORE FEATURES WORKING ==="
    
    # Test 1: Defer
    test_defer_parsing()
    
    # Test 2: Await
    test_await_parsing()
    
    # Test 3 & 4: Traits & Impl
    display "=== TRAITS & IMPL TEST ==="
    doc be Document("Report.pdf")
    doc.print_item()
    
    # Test 5: Operator Overloading
    display "=== OPERATOR OVERLOADING TEST ==="
    n1 be Number(5)
    n2 be Number(3)
    n3 be n1 + n2
    display "5 + 3 = " + type(n3.value)
    
    # Test 6: TCO
    display "=== TAIL CALL OPTIMIZATION TEST ==="
    fn loop_count(n):
        if n <= 0:
            display "Recursion complete"
            give back nothing
        if n <= 3:
            display "n = " + type(n)
        give back loop_count(n - 1)
    
    loop_count(5)
    
    display "✓ All 6 core language features implemented!"

test_features()
