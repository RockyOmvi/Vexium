use ai

display "=========================================================================="
display " 📊 VEX-EVAL PACKAGE — DYNAMIC MODEL EVALUATION & METRICS ENGINE"
display "=========================================================================="

fn accuracy(y_pred, y_true):
    give back accuracy_score(y_pred, y_true)

fn bleu(hypothesis, reference):
    give back bleu_score(hypothesis, reference)

fn perplexity(loss):
    give back exp(loss)

display "\n✓ [vex-eval v1.0.0] Initialized successfully!"
